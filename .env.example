# =============================================================================
# Open-Recruiter — Environment Variables Template
# =============================================================================
# 1. Copy this file:  cp .env.example .env.local
# 2. Fill in real values in .env.local
# 3. NEVER commit .env.local or any file containing real secrets
# 4. For Prisma CLI (migrations, studio), also copy DATABASE_URL into .env
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Supabase PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:your-password@your-project.supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# AUTH.JS v5 (next-auth@beta)
# Generate secret with:  npx auth secret
# Must be at least 32 characters of random data.
# -----------------------------------------------------------------------------
AUTH_SECRET="replace-with-output-of-npx-auth-secret"

# In production, set to your canonical public URL (e.g. https://open-recruiter.com)
AUTH_URL="http://localhost:3000"

# Uncomment on hosts that sit behind a reverse proxy (Vercel sets this automatically)
# AUTH_TRUST_HOST="true"

# -----------------------------------------------------------------------------
# OAUTH — LinkedIn
# Create app at: https://www.linkedin.com/developers/apps
# Required scopes: openid, profile, email
# Redirect URI:  {AUTH_URL}/api/auth/callback/linkedin
# -----------------------------------------------------------------------------
AUTH_LINKEDIN_ID="your-linkedin-client-id"
AUTH_LINKEDIN_SECRET="your-linkedin-client-secret"

# -----------------------------------------------------------------------------
# OAUTH — Google
# Create credentials at: https://console.cloud.google.com/
# Redirect URI:  {AUTH_URL}/api/auth/callback/google
# -----------------------------------------------------------------------------
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# -----------------------------------------------------------------------------
# OAUTH — Apple (Sign in with Apple)
# Configure at: https://developer.apple.com/account/resources/identifiers/
# Requires: Services ID, private key (.p8 file), Team ID, Key ID
# AUTH_APPLE_SECRET is the full PEM content of your .p8 key file.
# Redirect URI:  {AUTH_URL}/api/auth/callback/apple
# -----------------------------------------------------------------------------
AUTH_APPLE_ID="com.yourcompany.open-recruiter"
AUTH_APPLE_SECRET="-----BEGIN PRIVATE KEY-----\nYOUR_P8_KEY_CONTENT\n-----END PRIVATE KEY-----"

# -----------------------------------------------------------------------------
# EMAIL — Magic Links (Nodemailer SMTP)
# Use the connection string OR the individual vars below (not both).
# -----------------------------------------------------------------------------
EMAIL_SERVER="smtp://smtp-user:smtp-password@smtp.example.com:587"
EMAIL_FROM="Open-Recruiter <noreply@open-recruiter.com>"

# -- OR individual SMTP vars --
# EMAIL_SERVER_HOST="smtp.example.com"
# EMAIL_SERVER_PORT="587"
# EMAIL_SERVER_USER="smtp-user"
# EMAIL_SERVER_PASSWORD="smtp-password"
# EMAIL_FROM="Open-Recruiter <noreply@open-recruiter.com>"

# -----------------------------------------------------------------------------
# PAYREXX — Payment API
# Dashboard: https://payrexx.com → Account → API
# -----------------------------------------------------------------------------
PAYREXX_API_KEY="your-payrexx-api-key"
PAYREXX_INSTANCE_NAME="your-payrexx-instance-name"
PAYREXX_BASE_URL="https://api.payrexx.com/v1.0"
PAYREXX_WEBHOOK_SECRET="your-payrexx-webhook-secret"

# -----------------------------------------------------------------------------
# ENCRYPTION — AI API Key Storage
# Used by Node crypto (AES-256-GCM) to encrypt AI keys before storing in MySQL.
# Must be exactly 64 hex characters (= 32 bytes).
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
ENCRYPTION_KEY="replace-with-64-hex-character-random-string"

# -----------------------------------------------------------------------------
# FILE STORAGE — Supabase Storage
# Supabase Storage for profile photos and evidence uploads
# -----------------------------------------------------------------------------
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-key"
SUPABASE_STORAGE_BUCKET="open-recruiter-uploads"

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Open-Recruiter"

# GitHub repository URL (shown in the open-source mission banner on landing page)
NEXT_PUBLIC_GITHUB_URL="https://github.com/your-org/open-recruiter"

# -----------------------------------------------------------------------------
# PAYREXX — Static Payment Link (temporary, until full API integration)
# Create a payment link in your Payrexx dashboard and paste the URL here.
# This will be replaced by the API gateway flow later.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PAYREXX_PAYMENT_LINK="https://your-instance.payrexx.com/pay?tid=XXXX"
